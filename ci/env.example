# GitHub Actions Self-Hosted Runner Configuration
# Copy to ci/.env and fill in values before running setup.sh.

# Required: GitHub repository URL.
GITHUB_REPO_URL=https://github.com/asamarts/alint

# Required: Runner registration token.
# Get from: Settings → Actions → Runners → New self-hosted runner
GITHUB_TOKEN=

# Optional: Runner name (default: alint-runner)
RUNNER_NAME=alint-runner

# Optional: Runner labels (default: self-hosted,linux,alint)
RUNNER_LABELS=self-hosted,linux,alint

# Optional: Container image name (default: alint-runner)
RUNNER_IMAGE=alint-runner

# Optional: Container name (default: alint-runner)
CONTAINER_NAME=alint-runner
